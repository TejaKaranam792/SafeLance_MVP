{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "strict": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": ["./", "hardhat.config.ts", "scripts/**/*", "test/**/*"],
  "exclude": ["node_modules", "artifacts", "cache", "typechain-types"]
}
